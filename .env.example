# LeadScan Environment Variables
# Copy this file to .env and fill in your values

# Port the server listens on (default: 8080)
PORT=8080

# Path to the SQLite database file
# On Digital Ocean with a volume, use: /mnt/leadscan_data/leads.db
DB_PATH=./leads.db

# Default city for Craigslist scanning (craigslist subdomain, e.g. miami, newyork, chicago)
DEFAULT_CITY=miami

# How often to scan in minutes (default: 5)
SCAN_INTERVAL_MINUTES=5
